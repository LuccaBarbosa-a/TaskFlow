PORT=3001
NODE_ENV=development

# Banco de dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/taskflow?schema=public"

# Segredo do JWT — gere um valor aleatorio:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=coloque_um_segredo_aleatorio_aqui

# Origens permitidas pelo CORS (separadas por virgula)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
